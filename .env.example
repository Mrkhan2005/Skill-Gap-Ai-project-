[TEMPLATE]
# DEEPSEEK_API_KEY: Required for DeepSeek AI API calls.
# Get your API key from https://platform.deepseek.com/api_keys
# When deploying to HOSTINGER, add this exact key and its value to your Hostinger Environment Variables or .env file.
DEEPSEEK_API_KEY="your_actual_deepseek_api_key_here"

# APP_URL: The URL where this applet is hosted.
# In Hostinger, set this to your hosting domain (e.g., https://yourdomain.com).
APP_URL="https://yourdomain.com"

# NODE_ENV: Set to 'production' on your Hostinger environment to build and run highly optimized assets.
NODE_ENV="production"

# HOSTINGER DATABASE CONFIGURATION (Optional - if you decide to connect a Hostinger MySQL database)
# DB_HOST="localhost"
# DB_USER="u123456789_user"
# DB_PASSWORD="YourHostingerMySQLPassword"
# DB_NAME="u123456789_dbname"
# DB_PORT=3306
